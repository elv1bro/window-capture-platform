HOST=127.0.0.1
PORT=3000
NODE_ENV=development

REDIS_URL=redis://127.0.0.1:6379

# Change in production
SECRET=change-me-to-a-long-random-string
GUARD_SECRET=change-me-guard-secret

SESSION_TTL_SEC=86400
SLOT_INTERVAL=10

# Cloudflare Turnstile site key (test key works for dev)
TURNSTILE_SITEKEY=1x00000000000000000000AA

# Base domain for links in templates (set to your production domain)
BASE_DOMAIN=example.top

# Cookie domain for cross-subdomain sessions
COOKIE_DOMAIN=.example.top

# External assignment / TZ link (shown in nav and on landing)
ASSIGNMENT_URL=https://example.com/your-assignment.pdf

# Set to true when serving over HTTPS
COOKIE_SECURE=false
